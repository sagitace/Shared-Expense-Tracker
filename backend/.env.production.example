# Copy to backend/.env on the VM and fill in real values.
DEBUG=0
SECRET_KEY=replace-with-output-of: python -c "import secrets; print(secrets.token_urlsafe(50))"
ALLOWED_HOSTS=your-domain-or-vm-ip
CORS_ALLOWED_ORIGINS=http://your-domain-or-vm-ip
CSRF_TRUSTED_ORIGINS=http://your-domain-or-vm-ip
DB_ENGINE=django.db.backends.mysql
DB_NAME=shared_expense_tracker
DB_USER=tracker
DB_PASSWORD=replace-with-strong-password
DB_HOST=localhost
DB_PORT=3306
TIME_ZONE=UTC
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@example.com
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
